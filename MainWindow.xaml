<Window x:Class="RealiTLScannerGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RealiTLScanner"
        Height="780" Width="1100"
        MinHeight="650" MinWidth="900"
        Background="{StaticResource BgDarkBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Icon="icon.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⚡" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="#F0C040"/>
                <TextBlock Text="RealiTLScanner" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <TextBlock Text="TLS 1.3 Scanner" 
                           FontSize="13" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"
                           Margin="12,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Settings Panel -->
        <Border Grid.Row="1" 
                Background="{StaticResource BgCardBrush}" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="10" 
                Padding="20,16" 
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Mode Selector Tabs -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ModeAddr" Content="🌐  IP / CIDR / Domain" 
                                         Style="{StaticResource ModernRadioButton}" 
                                         IsChecked="True" GroupName="Mode"
                                         Checked="Mode_Changed"/>
                            <RadioButton x:Name="ModeFile" Content="📄  File" 
                                         Style="{StaticResource ModernRadioButton}" 
                                         GroupName="Mode"
                                         Checked="Mode_Changed"/>
                            <RadioButton x:Name="ModeUrl" Content="🔗  URL" 
                                         Style="{StaticResource ModernRadioButton}" 
                                         GroupName="Mode"
                                         Checked="Mode_Changed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Target Input -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TxtTarget" 
                             Style="{StaticResource ModernTextBox}" 
                             Grid.Column="0"
                             Tag="Enter IP, CIDR, or domain (e.g. 1.1.1.1, 10.0.0.0/24, example.com)"/>

                    <Button x:Name="BtnBrowse" Content="📁  Browse" 
                            Style="{StaticResource SecondaryButton}" 
                            Grid.Column="1" 
                            Margin="8,0,0,0" 
                            Visibility="Collapsed"
                            Click="BtnBrowse_Click"/>
                </Grid>

                <!-- Options Row -->
                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="PORT" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   Margin="2,0,0,5" FontFamily="Segoe UI"/>
                        <TextBox x:Name="TxtPort" Text="443" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                        <TextBlock Text="THREADS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   Margin="2,0,0,5" FontFamily="Segoe UI"/>
                        <TextBox x:Name="TxtThreads" Text="2" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="8,0,8,0">
                        <TextBlock Text="TIMEOUT (sec)" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   Margin="2,0,0,5" FontFamily="Segoe UI"/>
                        <TextBox x:Name="TxtTimeout" Text="10" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="8,0,0,0">
                        <TextBlock Text="OUTPUT FILE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   Margin="2,0,0,5" FontFamily="Segoe UI"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtOutput" Text="out.csv" Style="{StaticResource ModernTextBox}" Grid.Column="0"/>
                            <Button Content="..." Style="{StaticResource SecondaryButton}" 
                                    Grid.Column="1" Margin="4,0,0,0" Padding="10,8"
                                    Click="BtnOutputBrowse_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Checkboxes and Action Buttons -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkVerbose" Content="Verbose output" 
                                  Style="{StaticResource ModernCheckBox}" 
                                  Margin="0,0,24,0"/>
                        <CheckBox x:Name="ChkIpv6" Content="Enable IPv6" 
                                  Style="{StaticResource ModernCheckBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnStart" Content="▶  Start Scan" 
                                Style="{StaticResource ModernButton}" 
                                Click="BtnStart_Click" Margin="0,0,8,0"/>
                        <Button x:Name="BtnStop" Content="■  Stop" 
                                Style="{StaticResource DangerButton}" 
                                Click="BtnStop_Click" 
                                IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Results Area (Tabs: Log + Table) -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab Header -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="TabLog" Content="📋  Log Output" 
                                 Style="{StaticResource ModernRadioButton}" 
                                 IsChecked="True" GroupName="ResultTab"
                                 Checked="ResultTab_Changed"/>
                    <RadioButton x:Name="TabResults" Content="📊  Results" 
                                 Style="{StaticResource ModernRadioButton}" 
                                 GroupName="ResultTab"
                                 Checked="ResultTab_Changed"/>
                    <TextBlock x:Name="TxtResultCount" 
                               Text="" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Log Panel -->
            <Border x:Name="LogPanel" Grid.Row="1" 
                    Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="0,0,10,10" 
                    Padding="4">
                <ScrollViewer x:Name="LogScrollViewer" 
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Focusable="False">
                    <TextBlock x:Name="TxtLog" 
                               FontFamily="Cascadia Code, Consolas, Courier New" 
                               FontSize="12" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Padding="12,8"
                               Focusable="False"
                               Cursor="Arrow"/>
                </ScrollViewer>
            </Border>

            <!-- Results DataGrid -->
            <Border x:Name="ResultsPanel" Grid.Row="1" 
                    Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="0,0,10,10" 
                    Visibility="Collapsed">
                <DataGrid x:Name="ResultsGrid" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          CanUserSortColumns="True"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          Margin="4">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <ContextMenu.Template>
                                <ControlTemplate TargetType="ContextMenu">
                                    <Border Background="#1C2128" BorderBrush="#30363D" 
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </ControlTemplate>
                            </ContextMenu.Template>
                            <ContextMenu.Resources>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Foreground" Value="#E6EDF3"/>
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Bd" Background="Transparent" 
                                                        CornerRadius="4" Padding="12,7">
                                                    <TextBlock Text="{TemplateBinding Header}" 
                                                               Foreground="{TemplateBinding Foreground}"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#2D333B"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="Separator">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Separator">
                                                <Border Background="#30363D" Height="1" Margin="8,3"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ContextMenu.Resources>
                            <MenuItem Header="📋  Copy IP" Click="CopyIP_Click"/>
                            <MenuItem Header="🌐  Copy Domain" Click="CopyDomain_Click"/>
                            <MenuItem Header="📝  Copy Row" Click="CopyRow_Click"/>
                            <Separator/>
                            <MenuItem Header="📄  Copy All Results" Click="CopyAll_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="IP" Binding="{Binding IP}" Width="140"/>
                        <DataGridTextColumn Header="ORIGIN" Binding="{Binding Origin}" Width="180"/>
                        <DataGridTextColumn Header="CERT DOMAIN" Binding="{Binding CertDomain}" Width="200"/>
                        <DataGridTextColumn Header="CERT ISSUER" Binding="{Binding CertIssuer}" Width="*"/>
                        <DataGridTextColumn Header="GEO" Binding="{Binding GeoCode}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" 
                Background="{StaticResource BgCardBrush}" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="8"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{StaticResource TextSecondary}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock x:Name="TxtStatus" Text="Ready" 
                               FontSize="12" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="TxtElapsed" Text="" 
                           Grid.Column="2" 
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <Button Content="💾  Export CSV" 
                        Style="{StaticResource SecondaryButton}" 
                        Grid.Column="3" 
                        Padding="12,4"
                        FontSize="11"
                        Click="BtnExport_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
